{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome (Live Server)",
            "type": "chrome",
            "request": "launch",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Chrome (Localhost 8080)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
